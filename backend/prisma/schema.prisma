generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  username       String
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  settings       Json     @default("{\"timerDuration\": 10}")
  createdAt      DateTime @default(now())
}

model Problem{
  id String  @id @default(uuid())
  name String
  link String
  difficulty String
  category String
  createdAt DateTime @default(now())
  lists ProblemList[]
  sessions   Session[] 
}

model List{
   id          String   @id @default(uuid())
  name        String   @unique    // "NeetCode 150"
  slug        String   @unique    // "neetcode150"
  description String?            // optional description
  category    String
  createdAt   DateTime @default(now())
  problems    ProblemList[]
}

//join table
model ProblemList {
  problem   Problem @relation(fields: [problemId], references: [id])
  problemId String
  list      List    @relation(fields: [listId], references: [id])
  listId    String

  @@id([problemId, listId])     // composite primary key
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  problemId  String
  hintLevel  Int       @default(1)
  completed  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  problem    Problem   @relation(fields: [problemId], references: [id])
  attempts   Attempt[]
}

model Attempt {
  id        String   @id @default(uuid())
  sessionId String
  code      String
  hintLevel Int
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}